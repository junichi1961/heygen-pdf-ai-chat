# ─────────────────────────────────────────────────────────────
# ローカルバックエンド (server/) 用の環境変数
# このファイルを .env にコピーして値を埋めてください（.env は Git 管理外）
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────

# Express サーバーのポート（Vite からは /api でプロキシされます）
PORT=8787

# Claude API キー（チャット・見積生成に使用。ブラウザには出しません）
# 取得: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# 既定の Claude モデル（フロントの設定で上書き可）
DEFAULT_MODEL=claude-opus-4-8

# HeyGen API キー（Live Avatar のセッショントークン発行に使用）
# 取得: https://app.heygen.com/settings (Streaming/API)
HEYGEN_API_KEY=

# HeyGen のアバターID（Streaming Avatar の avatarName）。空なら SDK 既定を使用
HEYGEN_AVATAR_ID=

# RAG 埋め込みの方式: local（ゼロ依存・オフライン） | openai
EMBEDDING_PROVIDER=local

# EMBEDDING_PROVIDER=openai のときだけ必要
OPENAI_API_KEY=

# SQLite の保存先（既定: server/data/app.db）
# DB_PATH=server/data/app.db

# 見積書PDF(/api/pdf)で使う日本語フォント。既定は同梱の Noto Sans JP。
# 別フォントを埋め込みたい場合のみ TTF/OTF の絶対パスを指定
# PDF_FONT_PATH=
# PDF_FONT_BOLD_PATH=
